# =============================================================================
# Hola Climbing AI Worker — Environment Variables
# 본 파일은 `_workspace/01_architect_env.md`와 항상 일치해야 한다.
# 변경 시 양쪽 동시 수정.
# =============================================================================

# --- Worker --------------------------------------------------------------
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
LOG_LEVEL=INFO
MODEL_VERSION=rule_v1

# --- Redis (Spring과 동일 인스턴스) ---------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM_KEY=analysis:requests
REDIS_CONSUMER_GROUP=hola-ai-worker
REDIS_CONSUMER_NAME=worker-1
REDIS_PROGRESS_CHANNEL=analysis:progress
REDIS_BLOCK_MS=5000
REDIS_DLQ_KEY=analysis:requests:dlq

# --- GCS ----------------------------------------------------------------
GCS_BUCKET=hola-climbing-log-videos
GOOGLE_APPLICATION_CREDENTIALS=./keys/gcs-sa.json
GCS_DOWNLOAD_DIR=/tmp/hola-videos

# --- Callback (Worker → Spring) -----------------------------------------
CALLBACK_TIMEOUT_SECONDS=10
CALLBACK_MAX_RETRIES=3
CALLBACK_RETRY_INITIAL_SECONDS=1

# --- MediaPipe ----------------------------------------------------------
MP_MODEL_COMPLEXITY=1
MP_MIN_DETECTION_CONFIDENCE=0.5
FRAME_TARGET_FPS=15
